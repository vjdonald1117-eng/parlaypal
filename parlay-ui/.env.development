# Dev: talk to FastAPI directly on loopback (not via Vite proxy). Fixes many "Failed to fetch" cases when
# the proxy cannot reach :8000 or the dev server origin does not match the proxy path.
# Production builds do not load this file; leave VITE_API_BASE unset in .env.production for same-origin /api.
VITE_API_BASE=http://127.0.0.1:8000
